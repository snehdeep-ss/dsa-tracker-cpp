# Server
PORT=8080

# Database
DB_PATH=./dsa_tracker.db

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRY_DAYS=7

# Encryption (AES-256 key for storing LC/GH tokens)
ENCRYPTION_KEY=change_me_to_32_char_random_key_

# AI API
AI_API_KEY=your_anthropic_or_openai_key_here
AI_MODEL=claude-sonnet-4-20250514

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/integrations/github/callback

# Rate limiting
RATE_LIMIT_AUTH_RPM=5
